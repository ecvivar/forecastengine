# =============================================================================
# WorldCup Forecast Engine 2026 — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values before deploying.
#   cp .env.production.example .env
# =============================================================================

# --- REQUIRED ---

# Database connection string (Neon PostgreSQL recommended)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/worldcup_forecast

# JWT signing key — MUST be at least 32 characters, generated via:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-production

# Frontend URL for CORS (comma-separated for multiple origins)
CORS_ORIGINS=https://your-frontend-domain.com

# --- STRONGLY RECOMMENDED ---

# Sentry DSN for error tracking and APM (optional but recommended)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Redis connection string (optional — app works without Redis, but caching is disabled)
REDIS_URL=redis://host:6379/0

# --- OPTIONAL (defaults shown) ---

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Database connection pool settings
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Cache TTL in seconds (applies when Redis is connected)
CACHE_TTL=300

# JWT configuration
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Engine configuration
ENGINE_DEFAULT_SIMULATIONS=100000
ENGINE_POISSON_MAX_GOALS=10

# Collector API keys
COLLECTORS_FOOTBALL_DATA_API_KEY=

# Sentry traces sample rate (0.0 to 1.0)
SENTRY_TRACES_SAMPLE_RATE=0.1

# Enable debug mode (WARNING: never set to true in production)
DEBUG=false
